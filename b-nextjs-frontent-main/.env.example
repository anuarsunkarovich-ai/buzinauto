DATABASE_URI=mongodb+srv://username:password@cluster.mongodb.net/buzinavto_front?retryWrites=true&w=majority
PAYLOAD_SECRET=replace_with_a_long_random_secret
PAYLOAD_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000
API_URL=http://localhost:8000/api/v1

# Optional: if you want the browser to call Render directly instead of using the Next.js proxy.
NEXT_PUBLIC_API_URL=

# Optional: enable S3-compatible storage for uploads.
# Supabase Storage can be used here via its S3-compatible endpoint.
S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_ENDPOINT=
S3_FORCE_PATH_STYLE=false

# Optional: public base URL for uploaded files so Next/Image can optimize them.
UPLOADS_PUBLIC_URL=

# Optional: allow additional origins in Payload auth / CSRF checks.
PAYLOAD_EXTRA_ALLOWED_ORIGINS=
