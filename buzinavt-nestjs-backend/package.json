{
  "name": "nestjs-project",
  "version": "0.0.1",
  "description": "This project was built on the DDD architecture.",
  "author": "Maxim Kobylinsky",
  "private": true,
  "license": "MIT",
  "scripts": {
    "start": "node -r ./tsconfig-paths-bootstrap.js dist/main.js",
    "start:dev": "tsc-watch -p tsconfig.build.json --onSuccess \"node -r ./tsconfig-paths-bootstrap.js dist/main.js\"",
    "start:debug": "tsc-watch -p tsconfig.build.json --onSuccess \"node --inspect-brk -r ./tsconfig-paths-bootstrap.js dist/main.js\"",
    "build": "rimraf dist && tsc -p tsconfig.build.json",
    "prebuild": "rimraf dist && tsc -p tsconfig.build.json",
    "format": "prettier --write \"src/**/*.ts\"",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "prepare": "husky install",
    "precommit": "lint-staged",
    "check:env": "node -r ./tsconfig-paths-bootstrap.js dist/app/scripts/validate-env.script.js"
  },
  "hooks": {
    "pre-commit": "lint-staged && npm run prebuild",
    "post-commit": "git update-index --again"
  },
  "lint-staged": {
    "src/**/*.ts": [
      "node_modules/.bin/eslint --max-warnings=0",
      "prettier --write"
    ],
    "*.js": "eslint --cache --fix"
  },
  "dependencies": {
    "@lem0-packages/puppeteer-page-proxy": "^1.4.1",
    "@nestjs/bullmq": "^11.0.3",
    "@nestjs/cache-manager": "^3.0.1",
    "@nestjs/common": "^10.0.0",
    "@nestjs/config": "^3.2.2",
    "@nestjs/core": "^10.0.0",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/mongoose": "^10.1.0",
    "@nestjs/platform-express": "^10.0.0",
    "@nestjs/swagger": "^7.3.1",
    "@nestjs/throttler": "^5.1.2",
    "@qiwi/decorator-utils": "^4.5.10",
    "@sweet-monads/either": "^3.3.1",
    "@types/uuid": "^9.0.8",
    "axios": "^1.13.6",
    "bignumber.js": "^9.1.2",
    "bullmq": "^5.56.7",
    "cache-manager": "^7.0.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "flatted": "^3.3.3",
    "form-data": "^4.0.4",
    "iconv-lite": "^0.6.3",
    "joi": "^17.12.3",
    "keyv": "^5.4.0",
    "mongoose": "^8.9.3",
    "mongoose-autopopulate": "^1.1.0",
    "mongoose-delete": "^1.0.2",
    "mongoose-paginate-v2": "^1.8.5",
    "nestjs-pino": "^4.0.0",
    "pino-http": "^9.0.0",
    "puppeteer": "^24.9.0",
    "qs": "^6.14.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.1",
    "socks-proxy-agent": "^8.0.5",
    "swagger-ui-express": "^5.0.0",
    "tsc-watch": "^6.2.0",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.0.0",
    "@nestjs/schematics": "^10.0.0",
    "@nestjs/testing": "^10.0.0",
    "@types/express": "^4.17.17",
    "@types/jest": "^29.5.2",
    "@types/node": "^20.3.1",
    "@types/supertest": "^6.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.42.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "husky": "^7.0.4",
    "jest": "^29.5.0",
    "prettier": "^3.0.0",
    "rimraf": "^5.0.5",
    "source-map-support": "^0.5.21",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.0",
    "ts-loader": "^9.4.3",
    "ts-node": "^10.9.1",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.1.3"
  }
}
